nano ~user2/dmesg_script.sh

#!/bin/bash

if [ "$(whoami)" != "user2" ]; then
    echo "Ошибка: этот скрипт может выполнять только user2"
    exit 1
fi

/usr/bin/dmesg

chmod +x ~user2/dmesg_script.sh
chmod u+s ~user2/dmesg_script.sh

./dmesg_script.sh
dmesg: read kernel buffer failed: Operation not permitted

Возможно включена опция nosuid. Скомпилированные программы обычно работают в таком случае

#include <stdio.h>
#include <unistd.h>
#include <pwd.h>
#include <string.h>

int main() {
    uid_t uid = getuid();
    struct passwd *pw = getpwuid(uid);

    if (pw == NULL) {
        fprintf(stderr, "Ошибка: не удалось определить пользователя\n");
        return 1;
    }

    if (strcmp(pw->pw_name, "user2") != 0) {
        fprintf(stderr, "Ошибка: эту программу может выполнять только user2\n");
        return 1;
    }

    if (setuid(0) != 0) {
        fprintf(stderr, "Ошибка: не удалось установить права root\n");
        return 1;
    }

    execl("/bin/dmesg", "dmesg", NULL);

    perror("Ошибка: dmesg не выполнился");
    return 1;
}

